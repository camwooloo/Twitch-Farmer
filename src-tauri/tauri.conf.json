{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Twitch Farmer",
  "version": "0.1.9",
  "identifier": "you.aurora.twitchfarmer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Twitch Farmer",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Aurora",
    "category": "Utility",
    "shortDescription": "Twitch points & drops miner",
    "longDescription": "A beautiful desktop app to farm Twitch channel points, predictions and drops — with run-on-startup and tray support.",
    "resources": {
      "../backend-dist": "backend-dist"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
